# Database Configuration
# =====================

# For Local Development:
# DATABASE_URL="postgresql://postgres:password@localhost:5432/elomenedger?schema=public"

# For Vercel Postgres (automatically injected by Vercel):
# DATABASE_URL will be automatically set by Vercel when you create a Postgres database
# No need to manually configure this in production

# For Supabase:
# DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"

# For Neon (PostgreSQL Serverless):
# DATABASE_URL="postgresql://[user]:[password]@[neon_hostname]/[dbname]"

DATABASE_URL="postgresql://localhost:5432/elomenedger"